requires 1.3.5
cd .process
seqclean ${SEQUENCE_NAME} -reg
seqsubsky ${SEQUENCE_NAME} 2
setref bkg_${SEQUENCE_NAME} ${REFERENCE_INDEX}
getref bkg_${SEQUENCE_NAME}
register bkg_${SEQUENCE_NAME} -drizzle -scale=1.0 -pixfrac=0.9
stack r_bkg_${SEQUENCE_NAME} rej 3 3 -norm=addscale -output_norm -weight=wfwhm -out=stack
